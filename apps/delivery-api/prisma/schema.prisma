generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopifyWebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum CommerceSourcePlatform {
  SHOPIFY
  WOOCOMMERCE
}

enum CommerceConnectionStatus {
  ACTIVE
  DISABLED
}

enum CommerceSyncRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum CommerceRawOrderIngestStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  SKIPPED
  FAILED
}

enum WordPressPluginTokenStatus {
  ACTIVE
  REVOKED
}

enum DeliveryOrderStatus {
  PENDING
  READY
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
}

enum GeocodeStatus {
  NOT_REQUIRED
  PENDING
  RESOLVED
  FAILED
}

enum DeliveryStopStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  ARRIVED
  DELIVERED
  FAILED
  SKIPPED
  CANCELLED
}

enum DeliveryDayParseStatus {
  NOT_PROVIDED
  PARSED
  UNPARSED
  UNVERIFIED
}

enum OrderDeliveryFactReadiness {
  READY_TO_PLAN
  NEEDS_REVIEW
  SKIPPED
}

enum RoutePlanStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RouteOptimizationJobStatus {
  QUEUED
  RUNNING
  APPLIED
  TIMEOUT
  FAILED
  CANCELLED
}

enum RouteOptimizationJobStep {
  QUEUED
  CALLING_ENGINE
  APPLYING_RESULT
  COMPLETED
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VehicleType {
  CAR
  VAN
  TRUCK
  BIKE
  SCOOTER
  OTHER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum DriverEventType {
  ROUTE_STARTED
  ROUTE_PAUSED
  ROUTE_COMPLETED
  STOP_ARRIVED
  STOP_DELIVERED
  STOP_FAILED
  LOCATION_UPDATED
  NOTE_ADDED
}

enum DriverConsentType {
  LOCATION_INFORMATION
  PERSONAL_INFORMATION
}

enum DriverProofMediaKind {
  PHOTO
}

enum DriverProofMediaSource {
  CAMERA
  LIBRARY
}

enum RetentionJobRunStatus {
  SUCCEEDED
  FAILED
}

enum DriverAccountDeletionRequestStatus {
  REQUESTED
}

enum RouteGroupingStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RouteGroupingAssignmentStatus {
  UNASSIGNED
  ASSIGNED
  OVERLAP
  EXCLUDED
}

enum RouteGroupingVersionStatus {
  DRAFT
  CURRENT
  ARCHIVED
  ROLLED_BACK
}

enum RouteGroupingChildVersionStatus {
  CURRENT
  ARCHIVED
  ROLLED_BACK
}

enum DriverPushTokenStatus {
  ACTIVE
  REVOKED
  INVALID
}

enum DriverRouteNotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum DriverRouteNotificationAction {
  ASSIGNED
  CHANGED
}

enum CustomerRouteNotificationStatus {
  QUEUED
  SENT
}

model Shop {
  id                                String                             @id @default(uuid()) @db.Uuid
  appId                             String                             @default("clever") @db.Text
  shopDomain                        String                             @db.Text
  shopifyShopGid                    String?                            @db.Text
  apiVersion                        String                             @default("2026-04") @db.Text
  adminAccessTokenCiphertext        String?                            @db.Text
  adminAccessTokenExpiresAt         DateTime?                          @db.Timestamptz(6)
  adminRefreshTokenCiphertext       String?                            @db.Text
  adminRefreshTokenExpiresAt        DateTime?                          @db.Timestamptz(6)
  tokenScopes                       String[]                           @default([])
  tokenIssuedAt                     DateTime?                          @db.Timestamptz(6)
  installedAt                       DateTime                           @default(now()) @db.Timestamptz(6)
  uninstalledAt                     DateTime?                          @db.Timestamptz(6)
  defaultDepotAddress               String?                            @db.Text
  defaultDepotLatitude              Decimal?                           @db.Decimal(10, 7)
  defaultDepotLongitude             Decimal?                           @db.Decimal(10, 7)
  locale                            String?                            @db.Text
  routeScopeConfig                  Json?
  routeOpsUiSettings                Json?
  createdAt                         DateTime                           @default(now()) @db.Timestamptz(6)
  updatedAt                         DateTime                           @updatedAt @db.Timestamptz(6)
  webhookEvents                     ShopifyWebhookEvent[]
  orders                            Order[]
  orderItems                        OrderItem[]
  deliveryStops                     DeliveryStop[]
  routePlans                        RoutePlan[]
  drivers                           Driver[]
  vehicles                          Vehicle[]
  driverEvents                      DriverEvent[]
  driverConsentRecords              DriverConsentRecord[]
  driverProofMedia                  DriverProofMedia[]
  driverRouteFeedback               DriverRouteFeedback[]
  driverAccountDeletionRequests     DriverAccountDeletionRequest[]
  commerceConnections               CommerceConnection[]
  commerceConnectionAuditLogs       CommerceConnectionAuditLog[]
  commerceConnectionOrderMappings   CommerceConnectionOrderMapping[]
  commerceSyncRuns                  CommerceSyncRun[]
  commerceRawOrderIngests           CommerceRawOrderIngest[]
  commerceRawOrderIngestEvents      CommerceRawOrderIngestEvent[]
  adminNotifications                AdminNotification[]
  orderDeliveryFacts                OrderDeliveryFact[]
  wordpressPluginPairingCodes       WordPressPluginPairingCode[]
  routeOptimizationJobs             RouteOptimizationJob[]
  deliveryCustomerProfiles          DeliveryCustomerProfile[]
  deliveryCustomerProfileOrderLinks DeliveryCustomerProfileOrderLink[]
  routeGroupings                    RouteGrouping[]
  routeGroupingOrders               RouteGroupingOrder[]
  routeGroupingPolygons             RouteGroupingPolygon[]
  routeGroupingVersions             RouteGroupingVersion[]
  routeGroupingChildVersions        RouteGroupingChildVersion[]
  routeGroupingBranches             RouteGroupingBranch[]
  routeGroupingBranchOrderLocks     RouteGroupingBranchOrderLock[]
  inventories                       Inventory[]
  inventoryOrders                   InventoryOrder[]
  inventoryEvents                   InventoryEvent[]
  driverPushTokens                  DriverPushToken[]
  driverRouteNotificationAttempts   DriverRouteNotificationAttempt[]
  customerRouteNotificationFacts    CustomerRouteNotificationFact[]

  @@unique([appId, shopDomain])
  @@unique([appId, shopifyShopGid])
  @@index([shopDomain])
  @@map("shops")
}

model AdminNotification {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @db.Uuid
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type        String    @db.Text
  severity    String    @db.Text
  dedupeKey   String    @db.Text
  title       String    @db.Text
  body        String?   @db.Text
  href        String?   @db.Text
  orderId     String?   @db.Uuid
  routePlanId String?   @db.Uuid
  payload     Json?
  readAt      DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([shopId, dedupeKey])
  @@index([shopId, readAt, createdAt])
  @@index([shopId, type, createdAt])
  @@map("admin_notifications")
}

model CommerceConnection {
  id                       String                          @id @default(uuid()) @db.Uuid
  shopId                   String                          @db.Uuid
  shop                     Shop                            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  platform                 CommerceSourcePlatform
  status                   CommerceConnectionStatus        @default(ACTIVE)
  label                    String?                         @db.Text
  siteUrl                  String                          @db.Text
  shopDomain               String                          @db.Text
  timezone                 String?                         @db.Text
  consumerKeyCiphertext    String                          @db.Text
  consumerSecretCiphertext String                          @db.Text
  webhookSecretCiphertext  String                          @db.Text
  lastWebhookAt            DateTime?                       @db.Timestamptz(6)
  lastRestSyncAt           DateTime?                       @db.Timestamptz(6)
  lastVerifiedAt           DateTime?                       @db.Timestamptz(6)
  lastVerificationStatus   String?                         @db.Text
  credentialRotatedAt      DateTime?                       @db.Timestamptz(6)
  webhookSecretRotatedAt   DateTime?                       @db.Timestamptz(6)
  credentialFingerprint    String?                         @db.Text
  lastSyncAt               DateTime?                       @db.Timestamptz(6)
  lastSyncStatus           String?                         @db.Text
  createdAt                DateTime                        @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime                        @updatedAt @db.Timestamptz(6)
  wordpressPluginTokens    WordPressPluginToken[]
  wordpressPairingCodes    WordPressPluginPairingCode[]
  auditLogs                CommerceConnectionAuditLog[]
  orderMappingConfig       CommerceConnectionOrderMapping?
  syncRuns                 CommerceSyncRun[]
  rawOrderIngests          CommerceRawOrderIngest[]
  rawOrderIngestEvents     CommerceRawOrderIngestEvent[]
  orderDeliveryFacts       OrderDeliveryFact[]

  @@unique([shopId, platform, siteUrl])
  @@index([shopId, platform, status])
  @@index([platform, siteUrl])
  @@map("commerce_connections")
}

model CommerceSyncRun {
  id                   String                        @id @default(uuid()) @db.Uuid
  shopId               String                        @db.Uuid
  shop                 Shop                          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commerceConnectionId String                        @db.Uuid
  commerceConnection   CommerceConnection            @relation(fields: [commerceConnectionId], references: [id], onDelete: Cascade)
  platform             CommerceSourcePlatform
  source               String                        @default("wordpress_plugin") @db.Text
  trigger              String                        @db.Text
  status               CommerceSyncRunStatus         @default(QUEUED)
  requestPayload       Json
  pagesRead            Int?
  received             Int?
  created              Int?
  updated              Int?
  unchanged            Int?
  skipped              Int?
  readyToPlan          Int?
  needsReview          Int?
  geocodeResolved      Int?
  geocodeFailed        Int?
  geocodePending       Int?
  geocodeNotRequired   Int?
  warnings             Json
  errorMessage         String?                       @db.Text
  acceptedAt           DateTime                      @default(now()) @db.Timestamptz(6)
  startedAt            DateTime?                     @db.Timestamptz(6)
  completedAt          DateTime?                     @db.Timestamptz(6)
  createdAt            DateTime                      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                      @updatedAt @db.Timestamptz(6)
  rawOrderIngests      CommerceRawOrderIngest[]
  rawOrderIngestEvents CommerceRawOrderIngestEvent[]

  @@index([commerceConnectionId, status, createdAt])
  @@index([commerceConnectionId, createdAt])
  @@index([shopId, platform, createdAt])
  @@map("commerce_sync_runs")
}

model CommerceRawOrderIngest {
  id                   String                        @id @default(uuid()) @db.Uuid
  shopId               String                        @db.Uuid
  shop                 Shop                          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commerceConnectionId String                        @db.Uuid
  commerceConnection   CommerceConnection            @relation(fields: [commerceConnectionId], references: [id], onDelete: Cascade)
  syncRunId            String                        @db.Uuid
  syncRun              CommerceSyncRun               @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  platform             CommerceSourcePlatform        @default(WOOCOMMERCE)
  sourceSiteUrl        String                        @db.Text
  sourceOrderId        String                        @db.Text
  sourceOrderNumber    String?                       @db.Text
  sourceUpdatedAt      DateTime?                     @db.Timestamptz(6)
  rawPayload           Json
  rawPayloadSha256     String                        @db.Text
  idempotencyKey       String                        @db.Text
  chunkId              String                        @db.Text
  chunkIndex           Int
  status               CommerceRawOrderIngestStatus  @default(RECEIVED)
  canonicalOrderId     String?                       @db.Uuid
  processingStartedAt  DateTime?                     @db.Timestamptz(6)
  processedAt          DateTime?                     @db.Timestamptz(6)
  attemptCount         Int                           @default(0)
  failureCode          String?                       @db.Text
  failureMessage       String?                       @db.Text
  retryable            Boolean                       @default(true)
  receivedAt           DateTime                      @default(now()) @db.Timestamptz(6)
  createdAt            DateTime                      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                      @updatedAt @db.Timestamptz(6)
  events               CommerceRawOrderIngestEvent[]

  @@unique([commerceConnectionId, sourceOrderId, rawPayloadSha256])
  @@unique([syncRunId, chunkId, sourceOrderId, rawPayloadSha256])
  @@index([syncRunId, status, receivedAt])
  @@index([commerceConnectionId, sourceOrderId, receivedAt])
  @@map("commerce_raw_order_ingests")
}

model CommerceRawOrderIngestEvent {
  id                   String                  @id @default(uuid()) @db.Uuid
  shopId               String                  @db.Uuid
  shop                 Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commerceConnectionId String?                 @db.Uuid
  commerceConnection   CommerceConnection?     @relation(fields: [commerceConnectionId], references: [id], onDelete: SetNull)
  syncRunId            String?                 @db.Uuid
  syncRun              CommerceSyncRun?        @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  rawOrderIngestId     String?                 @db.Uuid
  rawOrderIngest       CommerceRawOrderIngest? @relation(fields: [rawOrderIngestId], references: [id], onDelete: SetNull)
  sourceLine           String                  @db.Text
  stage                String                  @db.Text
  decision             String                  @db.Text
  code                 String                  @db.Text
  severity             String                  @db.Text
  message              String                  @db.Text
  metadata             Json?
  sourceOrderId        String?                 @db.Text
  sourceOrderNumber    String?                 @db.Text
  rawPayloadSha256     String?                 @db.Text
  createdAt            DateTime                @default(now()) @db.Timestamptz(6)

  @@index([shopId, sourceOrderNumber, createdAt], map: "raw_ingest_events_shop_order_number_createdAt_idx")
  @@index([shopId, sourceOrderId, createdAt], map: "raw_ingest_events_shop_order_id_createdAt_idx")
  @@index([rawOrderIngestId, createdAt], map: "raw_ingest_events_raw_ingest_createdAt_idx")
  @@index([syncRunId, createdAt], map: "raw_ingest_events_sync_run_createdAt_idx")
  @@index([shopId, code, createdAt], map: "raw_ingest_events_shop_code_createdAt_idx")
  @@map("commerce_raw_order_ingest_events")
}

model CommerceConnectionAuditLog {
  id                   String              @id @default(uuid()) @db.Uuid
  shopId               String              @db.Uuid
  shop                 Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commerceConnectionId String?             @db.Uuid
  commerceConnection   CommerceConnection? @relation(fields: [commerceConnectionId], references: [id], onDelete: SetNull)
  actorSubject         String              @db.Text
  action               String              @db.Text
  status               String              @db.Text
  metadata             Json?
  createdAt            DateTime            @default(now()) @db.Timestamptz(6)

  @@index([shopId, createdAt])
  @@index([commerceConnectionId, createdAt])
  @@map("commerce_connection_audit_logs")
}

model CommerceConnectionOrderMapping {
  id                   String             @id @default(uuid()) @db.Uuid
  shopId               String             @db.Uuid
  shop                 Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commerceConnectionId String             @unique @db.Uuid
  commerceConnection   CommerceConnection @relation(fields: [commerceConnectionId], references: [id], onDelete: Cascade)
  version              Int                @default(1)
  config               Json
  discoveredPathStats  Json?
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)

  @@index([shopId])
  @@map("commerce_connection_order_mappings")
}

model WordPressPluginToken {
  id                   String                     @id @default(uuid()) @db.Uuid
  commerceConnectionId String                     @db.Uuid
  commerceConnection   CommerceConnection         @relation(fields: [commerceConnectionId], references: [id], onDelete: Cascade)
  tokenHash            String                     @unique @db.Text
  tokenPrefix          String                     @db.Text
  status               WordPressPluginTokenStatus @default(ACTIVE)
  issuedAt             DateTime                   @default(now()) @db.Timestamptz(6)
  lastUsedAt           DateTime?                  @db.Timestamptz(6)
  rotatedAt            DateTime?                  @db.Timestamptz(6)
  revokedAt            DateTime?                  @db.Timestamptz(6)
  createdAt            DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                   @updatedAt @db.Timestamptz(6)

  @@index([commerceConnectionId, status])
  @@map("wordpress_plugin_tokens")
}

model WordPressPluginPairingCode {
  id                   String             @id @default(uuid()) @db.Uuid
  commerceConnectionId String             @db.Uuid
  commerceConnection   CommerceConnection @relation(fields: [commerceConnectionId], references: [id], onDelete: Cascade)
  shopId               String             @db.Uuid
  shop                 Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  codeHash             String             @unique @db.Text
  siteUrl              String             @db.Text
  issuedBy             String?            @db.Text
  issuedAt             DateTime           @default(now()) @db.Timestamptz(6)
  expiresAt            DateTime           @db.Timestamptz(6)
  consumedAt           DateTime?          @db.Timestamptz(6)
  consumedBySiteUrl    String?            @db.Text
  failedAttemptCount   Int                @default(0)
  lastFailedAt         DateTime?          @db.Timestamptz(6)
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)

  @@index([commerceConnectionId, expiresAt])
  @@index([shopId, expiresAt])
  @@map("wordpress_plugin_pairing_codes")
}

model ShopifyWebhookEvent {
  id            String                    @id @default(uuid()) @db.Uuid
  shopId        String                    @db.Uuid
  shop          Shop                      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  webhookId     String                    @db.Text
  eventId       String?                   @db.Text
  topic         String                    @db.Text
  apiVersion    String?                   @db.Text
  triggeredAt   DateTime?                 @db.Timestamptz(6)
  rawBodySha256 String                    @db.Text
  payload       Json
  status        ShopifyWebhookEventStatus @default(RECEIVED)
  attemptCount  Int                       @default(0)
  lastError     String?                   @db.Text
  receivedAt    DateTime                  @default(now()) @db.Timestamptz(6)
  processedAt   DateTime?                 @db.Timestamptz(6)
  createdAt     DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime                  @updatedAt @db.Timestamptz(6)

  @@unique([shopId, webhookId])
  @@index([shopId, topic, receivedAt])
  @@index([status, receivedAt])
  @@map("shopify_webhook_events")
}

model Order {
  id                            String                             @id @default(uuid()) @db.Uuid
  shopId                        String                             @db.Uuid
  shop                          Shop                               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderGid               String                             @db.Text
  shopifyOrderLegacyId          BigInt?
  sourcePlatform                CommerceSourcePlatform             @default(SHOPIFY)
  sourceSiteUrl                 String?                            @db.Text
  sourceOrderId                 String?                            @db.Text
  sourceOrderNumber             String?                            @db.Text
  sourceUpdatedAt               DateTime?                          @db.Timestamptz(6)
  name                          String                             @db.Text
  email                         String?                            @db.Text
  phone                         String?                            @db.Text
  financialStatus               String?                            @db.Text
  fulfillmentStatus             String?                            @db.Text
  cancelledAt                   DateTime?                          @db.Timestamptz(6)
  processedAt                   DateTime?                          @db.Timestamptz(6)
  updatedAtShopify              DateTime?                          @db.Timestamptz(6)
  totalPriceAmount              Decimal?                           @db.Decimal(12, 2)
  currencyCode                  String?                            @db.Text
  shippingAddress               Json?
  rawPayload                    Json
  deliveryStatus                DeliveryOrderStatus                @default(PENDING)
  createdAt                     DateTime                           @default(now()) @db.Timestamptz(6)
  updatedAt                     DateTime                           @updatedAt @db.Timestamptz(6)
  orderItems                    OrderItem[]
  deliveryStops                 DeliveryStop[]
  deliveryFacts                 OrderDeliveryFact[]
  deliveryCustomerProfileLinks  DeliveryCustomerProfileOrderLink[]
  routeGroupingOrders           RouteGroupingOrder[]
  routeGroupingBranchOrderLocks RouteGroupingBranchOrderLock[]
  inventoryOrders               InventoryOrder[]
  inventoryEvents               InventoryEvent[]
  customerRouteNotifications    CustomerRouteNotificationFact[]

  @@unique([shopId, shopifyOrderGid])
  @@unique([shopId, sourcePlatform, sourceSiteUrl, sourceOrderId])
  @@index([shopId, name])
  @@index([shopId, sourcePlatform, sourceSiteUrl, sourceOrderNumber])
  @@index([shopId, sourcePlatform, sourceUpdatedAt])
  @@index([shopId, deliveryStatus, processedAt])
  @@map("orders")
}

model OrderItem {
  id              String           @id @default(uuid()) @db.Uuid
  shopId          String           @db.Uuid
  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId         String           @db.Uuid
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       Int
  variationId     Int              @default(0)
  lineIndex       Int
  name            String           @db.Text
  sku             String?          @db.Text
  options         Json
  quantity        Int
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6)
  inventoryEvents InventoryEvent[]

  @@unique([orderId, lineIndex])
  @@index([shopId, orderId])
  @@index([shopId, productId, variationId])
  @@map("order_items")
}

model Inventory {
  id        String           @id @default(uuid()) @db.Uuid
  shopId    String           @db.Uuid
  shop      Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String           @db.Text
  note      String?          @db.Text
  createdBy String?          @db.Text
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)
  orders    InventoryOrder[]
  events    InventoryEvent[]

  @@index([shopId, createdAt])
  @@map("inventories")
}

model InventoryOrder {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @db.Uuid
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inventoryId String    @db.Uuid
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  orderId     String    @db.Uuid
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addedBy     String?   @db.Text
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([inventoryId, orderId])
  @@index([shopId, orderId])
  @@map("inventory_orders")
}

model InventoryEvent {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @db.Uuid
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inventoryId String    @db.Uuid
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  orderId     String    @db.Uuid
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId String    @db.Uuid
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  action      String    @db.Text
  productId   Int
  variationId Int
  name        String    @db.Text
  sku         String?   @db.Text
  options     Json
  quantity    Int
  actor       String?   @db.Text
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([inventoryId, createdAt])
  @@index([shopId, orderId])
  @@index([shopId, productId, variationId])
  @@map("inventory_events")
}

model DeliveryStop {
  id                            String                         @id @default(uuid()) @db.Uuid
  shopId                        String                         @db.Uuid
  shop                          Shop                           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId                       String                         @db.Uuid
  order                         Order                          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recipientName                 String?                        @db.Text
  phone                         String?                        @db.Text
  address1                      String?                        @db.Text
  address2                      String?                        @db.Text
  city                          String?                        @db.Text
  province                      String?                        @db.Text
  postalCode                    String?                        @db.Text
  countryCode                   String?                        @db.Text
  latitude                      Decimal?                       @db.Decimal(10, 7)
  longitude                     Decimal?                       @db.Decimal(10, 7)
  geocodeStatus                 GeocodeStatus                  @default(PENDING)
  deliveryDate                  DateTime?                      @db.Date
  timeWindowStart               DateTime?                      @db.Timestamptz(6)
  timeWindowEnd                 DateTime?                      @db.Timestamptz(6)
  serviceMinutes                Int                            @default(5)
  priority                      Int                            @default(0)
  instructions                  String?                        @db.Text
  status                        DeliveryStopStatus             @default(PENDING)
  createdAt                     DateTime                       @default(now()) @db.Timestamptz(6)
  updatedAt                     DateTime                       @updatedAt @db.Timestamptz(6)
  routePlanStops                RoutePlanStop[]
  driverEvents                  DriverEvent[]
  driverProofMedia              DriverProofMedia[]
  routeGroupingOrders           RouteGroupingOrder[]
