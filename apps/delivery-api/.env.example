NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL / Prisma
DATABASE_URL=postgresql://clever:clever@localhost:5432/clever_route
POSTGRES_DB=clever_route
POSTGRES_USER=clever
POSTGRES_PASSWORD=clever
POSTGRES_PORT=5432
API_PORT=3000

# Driver API auth secret; required for driver login/session and route access APIs.
JWT_SECRET=change-me

# Generic server-side master key for encrypting customer connector credentials in DB.
# Generate with: node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# Internal-only API contract gate for WooCommerce credential onboarding.
# Do not use customer Woo keys/secrets here; operators enter those through the
# authenticated admin API and they are stored encrypted per shop/site.
CLEVER_ADMIN_API_TOKEN=
CLEVER_ADMIN_API_ACTOR=internal-operator
CLEVER_ADMIN_ALLOWED_SHOP_DOMAINS=*
DELIVERY_API_PUBLIC_URL=

# Driver proof media storage backend. Use local for development only; use s3 for production.
DRIVER_PROOF_MEDIA_STORAGE_BACKEND=local
DRIVER_PROOF_MEDIA_STORAGE_DIR=var/driver-proof-media
DRIVER_PROOF_MEDIA_S3_BUCKET=
DRIVER_PROOF_MEDIA_S3_REGION=
DRIVER_PROOF_MEDIA_S3_ACCESS_KEY_ID=
DRIVER_PROOF_MEDIA_S3_SECRET_ACCESS_KEY=
DRIVER_PROOF_MEDIA_S3_ENDPOINT=
DRIVER_PROOF_MEDIA_S3_FORCE_PATH_STYLE=false
DRIVER_PROOF_MEDIA_S3_SESSION_TOKEN=
DRIVER_PROOF_MEDIA_READ_ACCESS_TTL_SECONDS=300
DRIVER_PROOF_MEDIA_RETENTION_DAYS=180
DRIVER_PROOF_MEDIA_SCANNER_BACKEND=none
DRIVER_PROOF_MEDIA_SCANNER_URL=
DRIVER_PROOF_MEDIA_SCANNER_BEARER_TOKEN=
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BACKEND=none
DRIVER_PROOF_MEDIA_SCAN_MONITOR_URL=
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BEARER_TOKEN=
DRIVER_PROOF_MEDIA_CLEANUP_EVIDENCE_REF=

# Optional legacy Shopify compatibility. Leave unset for the WordPress/Woo main server
# unless running legacy Shopify token/webhook/order-sync compatibility paths.
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_TOKEN_ENCRYPTION_KEY=

# WooCommerce order ingestion defaults. Customer-specific Woo API keys/secrets belong
# in encrypted DB connector rows, not in shared product env files.
WOOCOMMERCE_SHOP_TIMEZONE=America/Toronto
WOOCOMMERCE_SYNC_LOOKBACK_DAYS=14
