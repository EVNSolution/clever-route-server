NODE_ENV=production
PORT=3000
LOG_LEVEL=info

POSTGRES_DB=clever_route
POSTGRES_USER=clever
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://clever:replace-with-strong-password@postgres:5432/clever_route

JWT_SECRET=replace-with-strong-random-secret
DRIVER_PROOF_MEDIA_STORAGE_BACKEND=local
DRIVER_PROOF_MEDIA_STORAGE_DIR=/app/var/driver-proof-media
DRIVER_PROOF_MEDIA_READ_ACCESS_TTL_SECONDS=300
DRIVER_PROOF_MEDIA_RETENTION_DAYS=180
DRIVER_PROOF_MEDIA_SCANNER_BACKEND=none
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BACKEND=none

# Optional legacy Shopify compatibility; keep unset for the WordPress/Woo main runtime
# unless a rollback/compatibility path explicitly needs these routes enabled.
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_TOKEN_ENCRYPTION_KEY=
