NODE_ENV=production
PORT=3000
LOG_LEVEL=info

POSTGRES_DB=clever_route
POSTGRES_USER=clever
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://clever:replace-with-strong-password@postgres:5432/clever_route

JWT_SECRET=replace-with-strong-random-secret

# Generic server-side master key for encrypting customer connector credentials in DB.
# Generate with: node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# Protected internal/admin API defaults. Customer Woo keys/secrets are entered through
# onboarding/admin flows and stored encrypted in DB connector rows, not in this file.
# Set CLEVER_ADMIN_ALLOWED_SHOP_DOMAINS to explicit comma-separated Woo/shop domains.
# Leaving it blank fails closed; use * only for a deliberate, reviewed compatibility exception.
CLEVER_ADMIN_API_TOKEN=
CLEVER_ADMIN_API_ACTOR=internal-operator
CLEVER_ADMIN_ALLOWED_SHOP_DOMAINS=
# Browser admin UI uses separate web-only secrets. Do not reuse CLEVER_ADMIN_API_TOKEN.
CLEVER_ADMIN_WEB_LOGIN_SECRET=
CLEVER_ADMIN_WEB_SESSION_SECRET=
CLEVER_ADMIN_WEB_COOKIE_NAME=clever_admin_ui
DELIVERY_API_PUBLIC_URL=https://clever-route.cleversystem.ai
PRIVACY_CONTACT_EMAIL=chase@evnsolution.com

# Initial production target: S3-less EC2/EBS local proof-media storage. The compose
# stack bind-mounts /srv/clever-route-server/data/driver-proof-media on the host.
DRIVER_PROOF_MEDIA_STORAGE_BACKEND=local
DRIVER_PROOF_MEDIA_STORAGE_DIR=/app/var/driver-proof-media
DRIVER_PROOF_MEDIA_READ_ACCESS_TTL_SECONDS=300
DRIVER_PROOF_MEDIA_RETENTION_DAYS=180
DRIVER_PROOF_MEDIA_SCANNER_BACKEND=none
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BACKEND=none

# Optional first-slice driver route map preview. Keep disabled until the delivery
# app/server smoke confirms route geometry coverage for the target tenant.
# Preview URLs are minted only from DELIVERY_API_PUBLIC_URL, not forwarded hosts.
# Set a dedicated preview secret before enabling in production.
DRIVER_ROUTE_MAP_PREVIEW_ENABLED=false
DRIVER_ROUTE_MAP_PREVIEW_SECRET=
DRIVER_ROUTE_MAP_PREVIEW_TTL_SECONDS=600

# Optional legacy Shopify compatibility; keep unset for the WordPress/Woo main runtime
# unless a rollback/compatibility path explicitly needs these routes enabled.
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_TOKEN_ENCRYPTION_KEY=

# WooCommerce order ingestion defaults. Customer-specific Woo API keys/secrets belong
# in encrypted DB connector rows, not in shared product env files.
WOOCOMMERCE_SHOP_TIMEZONE=America/Toronto
WOOCOMMERCE_SYNC_LOOKBACK_DAYS=14

# Route Ops map provider contract. Leave unset for default disabled map provider.
# Public OpenFreeMap or any public tile host must be explicitly allowlisted.
ROUTE_OPS_MAP_STYLE_URL=
ROUTE_OPS_MAP_PROVIDER_MODE=
ROUTE_OPS_MAP_ALLOWED_HOSTS=
ROUTE_OPS_MAP_ATTRIBUTION=

# Example public allowlist mode:
# ROUTE_OPS_MAP_STYLE_URL=/admin/ui/app/vendor/openfreemap-clever-lite.json
# ROUTE_OPS_MAP_PROVIDER_MODE=public_allowlisted
# ROUTE_OPS_MAP_ALLOWED_HOSTS=tiles.openfreemap.org
# ROUTE_OPS_MAP_ATTRIBUTION=OpenFreeMap / OpenMapTiles public providers

# Example self-hosted/same-host style mode:
# ROUTE_OPS_MAP_STYLE_URL=/admin/ui/app/vendor/openfreemap-self-hosted-fixture.json
# ROUTE_OPS_MAP_PROVIDER_MODE=self_hosted
# ROUTE_OPS_MAP_ALLOWED_HOSTS=

# Route Ops geocoding provider contract. Leave disabled unless an operator has
# approved the provider and runbook. The browser must not call geocoding hosts
# directly; delivery-api is responsible for policy guards, rate limiting, cache,
# and provider switchability.
GEOCODING_PROVIDER_MODE=disabled
GEOCODING_SEARCH_URL=
GEOCODING_USER_AGENT=
GEOCODING_RATE_LIMIT_PER_SECOND=1
GEOCODING_CACHE_TTL_DAYS=
GEOCODING_TIMEOUT_MS=10000
GEOCODING_PUBLIC_BULK_MAX_ATTEMPTS=25

# Public Nominatim-compatible mode is not production-default. If explicitly
# approved later, use an identifying User-Agent/Referer, keep requests
# bounded to approved operator/order-ingest flows, set GEOCODING_CACHE_TTL_DAYS
# to a positive value so settings/order lookups have durable DB metadata, keep
# GEOCODING_PUBLIC_BULK_MAX_ATTEMPTS low, and avoid autocomplete or unbounded
# bulk geocoding. Public mode is only allowed for a single delivery-api runtime;
# use a private provider or disable public geocoding before horizontal scaling.

# Route Ops route_engine optimizer. Leave ROUTE_ENGINE_BASE_URL blank to keep
# the existing CLEVER v1 fallback heuristic and avoid any route_engine HTTP calls.
# If enabled, use the internal compose/service-discovery URL and configure the
# same ROUTE_ENGINE_INTERNAL_TOKEN on route_engine; never commit the real token.
ROUTE_ENGINE_BASE_URL=
ROUTE_ENGINE_INTERNAL_TOKEN=
ROUTE_ENGINE_TIMEOUT_MS=120000
ROUTE_OPTIMIZATION_JOB_TIMEOUT_BUDGET_MS=180000
ROUTE_ENGINE_MODE=road_graph
ROUTE_ENGINE_OBJECTIVE=minimize_duration
ROUTE_ENGINE_SERVICE_REGION=ontario

# Route Ops road geometry provider. Leave OSRM_BASE_URL blank unless the
# internal-only Ontario OSRM service has been prepared and smoked on the host.
# With the compose osrm profile, use: OSRM_BASE_URL=http://osrm-ontario:5000
OSRM_BASE_URL=
OSRM_TIMEOUT_MS=10000
ROUTE_OPS_ROUTER_COVERAGE=ontario

# Route Ops web static artifact paths. Production images default to the mounted
# route-ops-web-static artifact at /app/external/route-ops-web; override only
# for local smoke or controlled rollback compatibility.
# ROUTE_OPS_WEB_DIST_PATH=/app/external/route-ops-web/dist
# ROUTE_OPS_WEB_PUBLIC_PATH=/app/external/route-ops-web/public
