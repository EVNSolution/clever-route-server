# Image metadata lives on the production host under /srv/clever-route-server/.deploy/*.env.
# Do not commit real runtime env or credentials here.
IMAGE_TAG=replace-with-immutable-git-sha
DELIVERY_API_IMAGE=ghcr.io/evnsolution/clever-route-server-delivery-api:replace-with-immutable-git-sha
DELIVERY_API_MIGRATE_IMAGE=ghcr.io/evnsolution/clever-route-server-delivery-api-migrate:replace-with-immutable-git-sha
PRISMA_SCHEMA_SHA=replace-with-sha256-of-apps-delivery-api-prisma-schema-prisma

# Optional deploy-host disk guard knobs. Defaults are set by scripts/deploy-route-ops-image.sh.
# ROUTE_OPS_DEPLOY_MIN_FREE_MB=4096
# ROUTE_OPS_DEPLOY_MIN_FREE_PERCENT=20
# ROUTE_OPS_IMAGE_KEEP_TAGS=replace-with-extra-sha-or-image-ref-if-needed
# ROUTE_OPS_IMAGE_PRUNE_DRY_RUN=1
